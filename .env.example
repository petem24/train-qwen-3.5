ROBOFLOW_API_KEY=replace_me
ROBOFLOW_DATASET_URL=
DATASET_FORMAT=coco

MODEL_ID=Qwen/Qwen3.5-0.8B
TRUST_REMOTE_CODE=true
ATTN_IMPLEMENTATION=sdpa
TORCH_DTYPE=bfloat16
BITS=4

LORA=true
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj
LORA_MODULES_TO_SAVE=

OCR_PROMPT=Read the text in this image. Answer with only the text.
LABEL_PREFIXES_TO_STRIP=
MASK_PROMPT=true

EPOCHS=100
BATCH_SIZE=8
EVAL_BATCH_SIZE=8
GRAD_ACCUM_STEPS=2
LR=1e-4
WEIGHT_DECAY=0
WARMUP_RATIO=0.03
NUM_WORKERS=2
GRADIENT_CHECKPOINTING=true
RESUME=

OUTPUT_DIR=/workspace/output
DATASET_DIR=/workspace/dataset

TENSORBOARD=true
WANDB=false
REPORT_TO=tensorboard
EVAL=true
EVAL_STRATEGY=steps
EVAL_STEPS=100
SAVE_STEPS=100
SAVE_TOTAL_LIMIT=3

MODEL_LOAD_JSON={}
TRAINING_ARGS_JSON={"dataloader_pin_memory":true,"dataloader_persistent_workers":true,"dataloader_prefetch_factor":4}
